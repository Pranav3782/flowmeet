PORT=5000
JWT_SECRET=your_jwt_secret_here

# ─────────────────────────────────────────────────────────────────
# GMAIL SMTP — Real email delivery
# ─────────────────────────────────────────────────────────────────
# Gmail address that will SEND the confirmation emails
GMAIL_USER=your_gmail_address@gmail.com

# Gmail App Password (16 chars, NO spaces) — NOT your regular password
# How to get it:
#  1. Go to https://myaccount.google.com/security
#  2. Enable "2-Step Verification" if not already on
#  3. Search "App passwords" → type any name → click Create
#  4. Copy the 16-char code here (remove spaces)
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Email address that receives all booking confirmations
NOTIFY_EMAIL=your_email@gmail.com
